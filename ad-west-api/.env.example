DATABASE_URL=postgresql://user:password@localhost:5432/ifca-auhwest
ENABLE_DB_PERSISTENCE=false
JWT_SECRET=change-me-local-secret
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
UPLOAD_DIR=/var/adwest-uploads
CORS_ORIGIN=http://localhost:3000,https://ad-west-56ez.vercel.app,https://*.vercel.app
TRUST_PROXY=true
# Supabase / managed Postgres usually require SSL (auto-enabled for *.supabase.com hosts).
# DATABASE_SSL=true
# Google OAuth/Gmail values are now managed in DB via Settings > Google Integration.
# Optional fallback envs can still be used for bootstrap/emergency override if needed.

