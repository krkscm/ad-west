{
  "framework": null,
  "installCommand": "npm install --prefix ad-west-web",
  "buildCommand": "npm run build",
  "outputDirectory": "ad-west-web/dist",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://ad-west-production.up.railway.app/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
