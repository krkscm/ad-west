# Local dev: relative URL proxied by Vite to the API.
VITE_API_URL=/api/v1
VITE_API_PROXY_TARGET=http://localhost:3001

# Vercel production: keep VITE_API_URL=/api/v1 and use vercel.json rewrite to Railway.
# Do NOT set VITE_API_URL to .../api (missing /v1) or a cross-origin Railway URL unless
# CORS_ORIGIN on the API includes your Vercel domain (e.g. https://*.vercel.app).
